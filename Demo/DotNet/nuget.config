<?xml version="1.0" encoding="utf-8"?>
<!--
  Lets this demo restore the managed UvfLib packages from a LOCAL pack feed before they are published
  to nuget.org. Produce the feed once with:   ../../BuildScripts/build.ps1 -Task pack
  (writes UvfLib.*.nupkg into Dist/Packages/nuget/). Then `dotnet run` here restores from it. Once the
  packages are on nuget.org, this file is no longer required.
-->
<configuration>
  <packageSources>
    <!-- Ignore any inherited (e.g. internal/unreachable) feeds; use only nuget.org + the local pack. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="uvf-local" value="../../Dist/Packages/nuget" />
  </packageSources>
</configuration>
